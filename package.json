{
  "name": "hacker-game",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "node --max-old-space-size=4096 node_modules/vitest/vitest.mjs run",
    "test:watch": "node --max-old-space-size=4096 node_modules/vitest/vitest.mjs",
    "test:coverage": "node --max-old-space-size=4096 node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:accessibility": "playwright test --grep @accessibility",
    "test:performance": "lighthouse http://localhost:4200 --output=json --output-path=./lighthouse-report.json",
    "test:bundle-size": "bundlesize",
    "test:all": "pnpm run lint && pnpm run test && pnpm run test:e2e && pnpm run build",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.0",
    "@types/three": "^0.184.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "@playwright/test": "^1.52.0",
    "axe-core": "^4.10.0",
    "lighthouse": "^12.0.0",
    "bundlesize": "^0.18.2"
  },
  "bundlesize": [
    {
      "name": "Main bundle",
      "path": "dist/hacker-game/browser/*.js",
      "maxSize": "500 kB"
    },
    {
      "name": "Styles",
      "path": "dist/hacker-game/browser/*.css",
      "maxSize": "100 kB"
    }
  ]
}