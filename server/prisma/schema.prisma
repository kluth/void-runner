generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SystemConfig {
  key   String @id
  value String
}

model Player {
  id               String           @id @default(uuid())
  username         String           @unique
  password         String?          
  provider         String?          
  providerId       String?          
  twoFactorSecret  String?
  twoFactorEnabled Boolean          @default(false)
  
  name             String
  score            Int              @default(0)
  reputation       Int              @default(0)
  
  // Base Game State
  credits          Int              @default(500)
  experience       Int              @default(0)
  botnetSize       Int              @default(0)
  campaignLevel    Int              @default(1)
  inventory        String           @default("[]") 
  software         String           @default("[]") 

  // Tactical Session State
  systemIntegrity  Int              @default(100)
  detectionLevel   Float            @default(0)
  activeDebuffs    String           @default("[]") // JSON of debuff objects
  artifacts        String           @default("[]") // JSON of unanalyzed artifacts
  publicExploits   String           @default("[]") // JSON array of mission types
  settings         String           @default("{}") // JSON of GameSettings
  
  teamId           String?
  team             Team?            @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeam          Team?            @relation("TeamLeader")
  sentMessages     PrivateMessage[] @relation("SentMessages")
  receivedMessages PrivateMessage[] @relation("ReceivedMessages")
  mediaCaptures    MediaCapture[]

  @@unique([provider, providerId])
}

model MediaCapture {
  id        String   @id @default(uuid())
  type      String   // 'IMAGE' | 'AUDIO'
  data      String   // Base64 encoded media or URL
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  createdAt DateTime @default(now())
}

model Team {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  leaderId    String   @unique
  leader      Player   @relation("TeamLeader", fields: [leaderId], references: [id])
  members     Player[] @relation("TeamMembers")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sender    String
  text      String
  teamId    String?
  timestamp DateTime @default(now())
}

model PrivateMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  timestamp  DateTime @default(now())
  
  sender   Player @relation("SentMessages", fields: [senderId], references: [id])
  receiver Player @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
