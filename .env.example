# VOID_RUNNER Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# CORE APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
WS_URL=ws://localhost:3000
FRONTEND_URL=http://localhost:4200

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/void_runner
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_key_here

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# =============================================================================
# PAYMENT PROCESSING
# =============================================================================
# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =============================================================================
# COMMUNICATION
# =============================================================================
# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid
SENDGRID_API_KEY=SG.your_api_key
SENDGRID_FROM_EMAIL=noreply@void-runner.com

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# =============================================================================
# AI & ML
# =============================================================================
# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Hugging Face
HUGGINGFACE_API_TOKEN=hf_your_token

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_CLOUD_KEY_FILE=path/to/key.json

# =============================================================================
# VISION & AUDIO
# =============================================================================
# Google Cloud Vision
GOOGLE_VISION_API_KEY=your_vision_api_key

# Google Cloud Speech
GOOGLE_SPEECH_API_KEY=your_speech_api_key

# AWS Rekognition
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# =============================================================================
# LOCATION & MAPPING
# =============================================================================
# Google Maps
GOOGLE_MAPS_API_KEY=your_maps_api_key

# Mapbox
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# =============================================================================
# BLOCKCHAIN & WEB3
# =============================================================================
# Ethereum
INFURA_PROJECT_ID=your_infura_project_id
INFURA_PROJECT_SECRET=your_infura_secret
ALCHEMY_API_KEY=your_alchemy_api_key

# IPFS
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_secret

# =============================================================================
# SOCIAL & GAMING
# =============================================================================
# Discord
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_guild_id

# Twitch
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# SECURITY
# =============================================================================
# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# =============================================================================
# MONITORING
# =============================================================================
# Sentry
SENTRY_DSN=https://your-key@sentry.io/project-id

# Datadog
DATADOG_API_KEY=your_api_key
DATADOG_APP_KEY=your_app_key

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# =============================================================================
# CDN & STORAGE
# =============================================================================
# Cloudflare
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# AWS S3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1

# =============================================================================
# GAME-SPECIFIC
# =============================================================================
# Neural Interface
NEURAL_API_URL=https://api.void-runner.com/neural
NEURAL_API_KEY=your_neural_api_key

# Surveillance System
SURVEILLANCE_API_URL=https://api.void-runner.com/surveillance
SURVEILLANCE_API_KEY=your_surveillance_api_key

# PVP Matchmaking
PVP_API_URL=https://api.void-runner.com/pvp
PVP_API_KEY=your_pvp_api_key

# Darknet Marketplace
DARKNET_API_URL=https://api.void-runner.com/darknet
DARKNET_API_KEY=your_darknet_api_key

# =============================================================================
# MOBILE & PUSH
# =============================================================================
# Apple Push
APNS_KEY_ID=your_key_id
APNS_TEAM_ID=your_team_id
APNS_BUNDLE_ID=com.void-runner.app
APNS_PRIVATE_KEY=your_private_key

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_server_key
FCM_SENDER_ID=your_sender_id

# =============================================================================
# WEBRTC
# =============================================================================
# Twilio Video
TWILIO_VIDEO_API_KEY=your_api_key
TWILIO_VIDEO_API_SECRET=your_api_secret

# Agora
AGORA_APP_ID=your_app_id
AGORA_APP_CERTIFICATE=your_certificate

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
# Test credentials
TEST_USER_EMAIL=test@void-runner.com
TEST_USER_PASSWORD=test_password_123
TEST_ADMIN_EMAIL=admin@void-runner.com
TEST_ADMIN_PASSWORD=admin_password_123

# Debug settings
DEBUG=true
LOG_LEVEL=debug

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit .env files to version control
# 2. Use different values for development/production
# 3. Rotate keys regularly
# 4. Monitor API usage
# 5. Set up alerts for unusual activity
# 6. Use environment-specific configurations
# 7. Document any custom integrations
# 8. Test all integrations thoroughly
# 9. Implement proper error handling
# 10. Use secure storage for sensitive data
